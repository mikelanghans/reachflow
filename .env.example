# ─── ReachFlow Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git. Add it to .gitignore.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found at: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-side only — never expose to the browser
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Found at: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Unipile (LinkedIn API) ────────────────────────────────────────────────────
# Found at: app.unipile.com → Settings → API Keys
UNIPILE_API_KEY=...
UNIPILE_WEBHOOK_SECRET=...   # Set when creating a webhook in Unipile dashboard

# ── Stripe ────────────────────────────────────────────────────────────────────
# Found at: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...       # Use sk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...     # Found in dashboard.stripe.com → Webhooks

# Price IDs — create these in Stripe → Products
# Each is a recurring monthly price attached to a product
STRIPE_PRICE_STARTER=price_...      # $49/mo — 3 clients
STRIPE_PRICE_PRO=price_...          # $129/mo — 10 clients
STRIPE_PRICE_AGENCY_PLUS=price_...  # $299/mo — unlimited

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://app.reachflow.io    # Your Vercel domain (or custom domain)
